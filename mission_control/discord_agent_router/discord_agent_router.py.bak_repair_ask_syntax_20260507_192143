def sanitize(text: str) -> str:
    patterns = [
        r"(?i)(token|secret|password|pass|api[_-]?key)\s*[:=]\s*\S+",
        r"\b[A-Za-z0-9_\-]{24}\.[A-Za-z0-9_\-]{6}\.[A-Za-z0-9_\-]{20,}\b",
        r"xox[baprs]-[A-Za-z0-9\-]+",
        r"sk-[A-Za-z0-9_\-]{20,}",
    ]
    cleaned = text or ""
    for pat in patterns:
        cleaned = re.sub(pat, lambda m: ((m.group(1) if m.lastindex else m.group(0).split("=", 1)[0]) + "=***REDACTED***"), cleaned)
    return cleaned

def trim(text: str, limit: int = MAX_OUTPUT) -> str:
    text = sanitize((text or "").strip())
    if not text:
        text = "Kein Inhalt vorhanden."
    if len(text) <= limit:
        return text
    return text[:limit] + "\n...[gekürzt]"

def read_text(path: Path, limit: int = MAX_OUTPUT) -> str:
    if not path.exists():
        return f"Datei nicht gefunden: {path}"
    return trim(path.read_text(encoding="utf-8", errors="ignore"), limit)

def cmd(cmdline: str, timeout: int = 6) -> str:
    try:
        return subprocess.run(
            ["bash", "-lc", cmdline],
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            timeout=timeout,
        ).stdout
    except Exception as exc:
        return f"{type(exc).__name__}: {exc}"

def compact_status() -> str:
    failed = cmd("systemctl --user --failed --no-pager | head -20", 5)
    timers = cmd("systemctl --user list-timers --all --no-pager | grep -E 'openclaw|shadowmaker|security|shadowops|NEXT|LEFT' || true", 5)
    webui = cmd("curl -I --max-time 3 http://127.0.0.1:3000 2>&1 | head -8 || true", 4)
    courier_file = LATEST_FILES["courier"]
    courier = "Courier latest nicht vorhanden."
    if courier_file.exists():
        txt = courier_file.read_text(encoding="utf-8", errors="ignore")
        lines = []
        for line in txt.splitlines():
            if any(k in line for k in ["Gesamt erfasste Mails", "P1 Heute", "P2 Diese Woche", "P3 Lesen", "Fehler/fehlende"]):
                lines.append(line)
        courier = "\n".join(lines) if lines else "Courier latest vorhanden."

    return trim(
        "**Shadowmaker Status**\n\n"
        "**User Failed**\n"
        f"```text\n{failed}\n```\n"
        "**Timer**\n"
        f"```text\n{timers}\n```\n"
        "**WebUI**\n"
        f"```text\n{webui}\n```\n"
        "**Courier Kurzlage**\n"
        f"```text\n{courier}\n```",
        1800,
    )

